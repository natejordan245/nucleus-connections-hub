# --- App mode ---
# `true`  → demo mode. Sign-in is bypassed; a synthetic persona cookie is set.
#           No Supabase calls, no real auth. The "Try the demo" CTA is the
#           primary path on the login page.
# `false` → real mode. Supabase Auth is the only path; demo CTA is hidden.
NEXT_PUBLIC_APP_MODE=demo

# --- Supabase (only required when NEXT_PUBLIC_APP_MODE=real) ---
# Public — used by the browser + server clients for auth.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by privileged server-side reads (admin tasks, RLS bypass).
# DO NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
