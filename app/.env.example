# --- App mode ---
# `demo` → no auth, hardcoded data, persona-picker login.
#          Use this for sales calls, judging, walkthroughs.
# `live` → Supabase Auth + Supabase-backed data store.
#          Real users, real persistence. Demo lane is reachable at /login?mode=demo.
NEXT_PUBLIC_APP_MODE=demo

# --- Supabase (only required when NEXT_PUBLIC_APP_MODE=live) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the live data store for privileged reads/writes.
# DO NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (live mode embeddings + LLM rerank) ---
# Required when NEXT_PUBLIC_APP_MODE=live for matchmaking to produce ranked
# candidates. Missing key → onboarding still works but profiles persist with
# a NULL embedding (matchesFor falls back to []).
OPENAI_API_KEY=
