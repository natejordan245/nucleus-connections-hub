# --- Service layer mode (frontend ↔ API boundary) ---
# `mock` — frontend talks to in-process MockServices (no API server needed)
# `real` — frontend uses HTTP services calling /api/* route handlers
NEXT_PUBLIC_SERVICE_MODE=mock

# --- Data layer mode (API ↔ data layer boundary) ---
# `mock` — API routes use in-memory mock data layer (no DB / OpenAI / Affinity)
# `real` — API routes use Supabase + OpenAI + Affinity
DATA_MODE=mock

# --- Real-mode credentials (only required if DATA_MODE=real) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

# --- Affinity (outbound CRM) ---
# false → never call Affinity, only log payloads to in-memory store for the demo
AFFINITY_LIVE=false
AFFINITY_API_KEY=
AFFINITY_LIST_NAME=Nucleus Connections — Mutual Match

# --- Squarespace inbound webhook ---
SQUARESPACE_WEBHOOK_SECRET=
